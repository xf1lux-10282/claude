{
  "env": {
    "AUTO_COMMIT_ON_SESSION_END": "true",
    "AUTO_PUSH": "true",
    "AUTO_PULL_ON_SESSION_START": "true",
    "REMOTE_CONTROL_AT_STARTUP": "true"
  },
  "permissions": {
    "allow": [
      "Bash(git pull:*)",
      "Bash(git rebase:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git fetch:*)",
      "Bash(git push:*)",
      "Bash(rm:*)",
      "Bash(chmod:*)",
      "Bash(launchctl load:*)",
      "Bash(launchctl start:*)",
      "Bash(launchctl list:*)",
      "Bash(launchctl unload:*)",
      "Bash(cat:*)",
      "Bash(\"$HOME/.local/bin/vault-auto-sync.sh\")"
    ],
    "deny": [],
    "ask": []
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/conversation_start.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/session_end.sh",
            "timeout": 30
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/pre_compact.sh",
            "timeout": 30
          }
        ]
      }
    ]
  }
}
